# Job Sniper — API Keys
#
# Place this file at ~/.job-sniper/.env (recommended) or in your current
# working directory. The tool checks ~/.job-sniper/.env first, then cwd.
#
# To set up:
#   mkdir -p ~/.job-sniper
#   cp .env.example ~/.job-sniper/.env
#   # then edit ~/.job-sniper/.env with your real keys

# Apollo API — contact discovery (10,000 credits/month free)
APOLLO_API_KEY=your_apollo_key_here
# Hunter API — email verification primary (25 verifications/month free)
HUNTER_API_KEY=your_hunter_key_here
# ZeroBounce API — email verification fallback (100 verifications/month free)
ZEROBOUNCE_API_KEY=your_zerobounce_key_here
